{
  "adapter_image_generation": {
    "description": "文生图 / image-generation 适配器 (/v1/images/generations)",
    "hint": "按 OpenAI 兼容风格配置。base_url 形如 https://api.x.com",
    "type": "object",
    "items": {
      "base_url": {
        "description": "Base URL",
        "type": "string",
        "default": ""
      },
      "api_key": {
        "description": "API Key",
        "type": "string",
        "default": ""
      },
      "model": {
        "description": "模型名",
        "type": "string",
        "default": "dall-e-3"
      },
      "size": {
        "description": "图片尺寸(可手填, 如 1024x1024 / 2048x1152 / 4096x4096 / 16:9)",
        "type": "string",
        "default": "1024x1024",
        "hint": "支持任意尺寸。填 WxH 或 比例(如 16:9)。doubao-seedream-4.5 这类模型可能要求至少 1920x1920。"
      },
      "watermark": {
        "description": "水印开关（默认 false，即无水印；auto 表示不传该字段）",
        "type": "string",
        "default": "false",
        "options": [
          "false",
          "true",
          "auto"
        ],
        "hint": "doubao-seedream-4.5 默认可能带水印；保持 false 可请求无水印输出。若上游不支持 watermark 字段，可设为 auto。"
      },
      "n": {
        "description": "生成数量",
        "type": "int",
        "default": 1
      }
    }
  },
  "adapter_image_edits": {
    "description": "图生图 / 图像编辑 / image-edits 适配器 (/images/edits)",
    "type": "object",
    "items": {
      "base_url": {
        "description": "Base URL",
        "type": "string",
        "default": ""
      },
      "api_key": {
        "description": "API Key",
        "type": "string",
        "default": ""
      },
      "model": {
        "description": "模型名",
        "type": "string",
        "default": "gpt-image-1"
      },
      "size": {
        "description": "输出尺寸(可手填, 如 1024x1024 / 1536x864)",
        "type": "string",
        "default": "1024x1024",
        "hint": "可手填任意尺寸"
      }
    }
  },
  "adapter_openai_chat": {
    "description": "文生视频(走对话) / openai 适配器 (/v1/chat/completions)",
    "type": "object",
    "items": {
      "base_url": {
        "description": "Base URL",
        "type": "string",
        "default": ""
      },
      "api_key": {
        "description": "API Key",
        "type": "string",
        "default": ""
      },
      "model": {
        "description": "模型名",
        "type": "string",
        "default": "gpt-4o"
      },
      "system_prompt": {
        "description": "系统提示词（可空）",
        "type": "text",
        "default": ""
      }
    }
  },
  "adapter_openai_video": {
    "description": "文生视频 / openai-video 适配器 (/v1/video/generations)",
    "type": "object",
    "items": {
      "base_url": {
        "description": "Base URL",
        "type": "string",
        "default": ""
      },
      "api_key": {
        "description": "API Key",
        "type": "string",
        "default": ""
      },
      "model": {
        "description": "模型名",
        "type": "string",
        "default": "sora"
      },
      "seconds": {
        "description": "视频时长(秒)",
        "type": "int",
        "default": 8
      },
      "poll_interval": {
        "description": "轮询间隔(秒)",
        "type": "float",
        "default": 3
      },
      "poll_max_wait": {
        "description": "轮询最大等待(秒)",
        "type": "int",
        "default": 600
      }
    }
  },
  "video_via_strategy": {
    "description": "文生视频优先使用哪个适配器",
    "type": "string",
    "default": "openai_video",
    "options": [
      "openai_video",
      "openai_chat"
    ]
  },
  "image_to_image_strategy": {
    "description": "图生图优先使用哪个适配器",
    "type": "string",
    "default": "image_edits",
    "options": [
      "image_edits",
      "image_generation"
    ],
    "hint": "普通 OpenAI 图像编辑用 image_edits；doubao-seedream-4.5 这类在 /v1/images/generations 同时支持图生图的模型用 image_generation。"
  },
  "image_to_video_strategy": {
    "description": "图生视频优先使用哪个适配器",
    "type": "string",
    "default": "openai_video",
    "options": [
      "openai_video",
      "image_edits"
    ]
  },
  "user_whitelist": {
    "description": "用户白名单 ID（逗号、空格或换行分隔；留空不限制用户）",
    "type": "string",
    "default": "",
    "hint": "填写 event.get_sender_id() 对应的用户 ID。示例：10001,10002"
  },
  "group_whitelist": {
    "description": "群聊白名单 ID（逗号、空格或换行分隔；留空不限制群聊）",
    "type": "string",
    "default": "",
    "hint": "仅限制群聊消息；私聊不会因为群聊白名单被拦截。示例：123456789,987654321"
  },
  "deny_message": {
    "description": "无权限提示语",
    "type": "string",
    "default": "❌ 你没有权限使用画图/视频插件。"
  },
  "image_reference": {
    "description": "上一张图片引用",
    "type": "object",
    "items": {
      "enable_previous_image": {
        "description": "当前消息未带图时，是否自动使用同会话同用户的上一张图片",
        "type": "string",
        "default": "true",
        "options": [
          "true",
          "false"
        ],
        "hint": "开启后，图生图/图生视频可复用用户上次发送的图片，或插件上次回复给该用户的图片。"
      },
      "previous_image_ttl": {
        "description": "上一张图片缓存有效期（秒，0 表示不过期）",
        "type": "int",
        "default": 1800,
        "hint": "默认 1800 秒。缓存只保存在内存中，插件重载后会清空。"
      }
    }
  },
  "media": {
    "description": "媒体处理",
    "type": "object",
    "items": {
      "save_dir": {
        "description": "保存目录(相对 data/)",
        "type": "string",
        "default": "imagegen"
      },
      "proxy": {
        "description": "下载代理(可空)",
        "type": "string",
        "default": ""
      },
      "timeout": {
        "description": "HTTP 超时(秒)",
        "type": "int",
        "default": 300
      }
    }
  }
}
